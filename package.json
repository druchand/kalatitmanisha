{
  "name": "kalatitmanisha",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8082",
    "start:tunnel": "expo start --go --tunnel -c --port 8081",
    "android": "expo start --port 8082 --android",
    "ios": "expo start --port 8082 --ios",
    "web": "expo start --port 8082 --web",
    "web:build": "expo export --platform web",
    "web:preview": "npx serve dist -l 4173",
    "web:test:prod": "npm run web:build && npm run web:preview",
    "test": "jest",
    "test:smoke": "jest tests/smoke --runInBand",
    "type-check": "tsc --noEmit",
    "tailwind:build": "tailwindcss -i tailwind.css -o web.css"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "babel-preset-expo": "^54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-audio": "^1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "^19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "lucide-react": "^0.563.0",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^12.3.1",
    "react-native-tts": "^4.1.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-web-webview": "file:third_party/react-native-web-webview",
    "react-native-webview": "13.15.0",
    "react-native-youtube-iframe": "file:third_party/react-native-youtube-iframe"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "~29.7.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
